{
  "name": "finca",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "typecheck": "npm run typecheck --workspace frontend",
    "dev:backend": "python3 -m uvicorn backend.main:app --reload",
    "install:frontend": "npm install --workspace frontend",
    "install:backend": "python3 -m pip install -r backend/requirements.txt"
  }
}
